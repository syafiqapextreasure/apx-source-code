<!DOCTYPE html>
<html lang="en" xmlns:th="http://www.thymeleaf.org"
	th:replace="~{base::layout(~{::section})}">
<head>

<meta charset="ISO-8859-1">
<title>Insert title here</title>

</head>
<body>
	<section>


		<!-- SweetAlert2 CDN -->
		<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

		<script
			src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>

		<div class="membership-form-main">
			<h1 class="mb-3">BORANG DAFTAR KEAHLIAN PPK</h1>


			<div id="memberform-id"
				class="container membership-form d-flex flex-column gap-5">
				<form th:action="@{/submitForm}" method="POST"
					enctype="multipart/form-data" class="mb-3" id="formId">
					<div class="mb-3">
						<!-- Hidden input to hold the list data -->
						<input type="hidden" name="selectedItems" id="selectedItems" /> <input
							type="hidden" name="messageRespon" id="messageResponse"
							th:value='${message}' />
						<fieldset id="fieldset-design">
							<legend id="legend-title">Maklumat Peribadi</legend>
							<div class="row mb-3">
								<div class="col-md-6">
									<label for="portalId" class="form-label">Id Pengguna
										Portal PPJ<span class="cus-red">*</span>

									</label> <input type="text" class="form-control" id="portalId"
										name="Tanggungan_Id_Pengguna_Portal_PPJ" /> <span
										id="errorportalId" class="error-message" style="display: none">Please
										eneter Id Pengguna Portal PPJ</span>
								</div>
								<div class="col-md-6">
									<label for="lokasiPPK" class="form-label">Lokasi PPK
										Pilihan<span class="cus-red">*</span>
									</label> <select name="branchLocation" id="branchLocation"
										class="form-select">
										<option th:each="branch : ${branchLocations}"
											th:value="${branch.code}" th:text="${branch.desc}">
											<!-- <option th:each="branch : ${branchLocations}"
											th:value="${branch.code}" th:text="${branch.desc}">
										</option> -->
									</select> <span id="branchError" class="error-message"
										style="display: none">Please choose branch Portal PPJ</span>



								</div>
							</div>
							<div class="row mb-3">
								<div class="col-md-6">
									<label for="nama" class="form-label">Nama<span
										class="cus-red">*</span></label> <input type="text"
										class="form-control" id="nama" name="namaAhli" required /> <span
										class="error-message" id="errornameId" style="display: none;">Please
										enter your nama</span>
								</div>
								<div class="col-md-6">
									<label for="noKP" class="form-label">No. K/P<span
										class="cus-red">*</span></label> <input type="text"
										class="form-control" id="noKP" name="No_KP" /> <span
										class="error-message" id="noKPerror" style="display: none;">Please
										enter No. KP</span>
								</div>

							</div>
							<div class="row mb-3">
								<div class="col-md-6">
									<label for="dob" class="form-label">Tarikh Lahir <span
										class="cus-red">*</span></label> <input type="date"
										class="form-control" id="myDate" name="dob" /> <span
										class="error-message" id="myDateError" style="display: none;">Please
										choose Trikh Lahir</span>
								</div>
								<div class="col-md-6">
									<label for="phone" class="form-label">No. Telefon</label><span
										class="cus-red">*</span> <input type="tel"
										class="form-control" id="phone" name="phone" maxlength="15"
										pattern="\d{1,15}" />
									<!-- <span class="noTelefonError"
										style="display: none;" id="noTelefonError">Please enter
										a valid No. Telefon (max length 15)</span> -->
								</div>

							</div>
							<div class="row mb-3">
								<div class="col-md-6">
									<label for="warganegara" class="form-label">Warganegara<span
										class="cus-red">*</span></label>
									<div class="d-flex flex-wrap gap-md-5 gap-2">
										<div class="form-check">
											<input class="form-check-input" type="radio" id="warGanYa"
												value="ya" required name="agecate" /> <label
												class="form-check-label" for="warGanYa">Ya</label>
										</div>
										<div class="form-check">
											<input class="form-check-input" type="radio" name="agecate"
												id="warGanTidak" value="tidak" /> <label
												class="form-check-label" for="warGanTidak">Tidak</label>
										</div>
									</div>
									<span id="warGanError" class="error-message"
										style="display: none; color: red;">This field is
										required</span>
								</div>



								<div class="col-md-6">
									<label for="bangsa" class="form-label">Bangsa</label> <input
										type="text" class="form-control" name="passport" id="bangsa" />
								</div>
							</div>
						</fieldset>
					</div>
					<div id="fieldsets-container">
						<div class="mb-3">
							<!-- Form for user to fill in -->
							<fieldset id="fieldset-design">
								<legend id="legend-title">
									Maklumat Tanggungan
									<button type="button" class="plusSign">+</button>
								</legend>

								<!-- Form Section -->
								<div class="formSection">
									<div class="row mb-3">
										<div class="col-md-6">
											<label for="idpengguna" class="form-label">Id
												Pengguna Tanggungan<span class="cus-red"></span>
											</label> <input type="text" class="form-control idpengguna"
												name="Tanggungan_Id_Pengguna_Tanggungan"
												id="Tanggungan_Id_Pengguna_Tanggungan" />
										</div>
										<div class="col-md-6">
											<label for="nokptanggungan" class="form-label">No. KP
												Tanggungan</label> <input type="text"
												class="form-control nokptanggungan" name="No_KP"
												id="nokptanggungan" />
										</div>
									</div>
									<div class="row mb-3">
										<div class="col-md-6">
											<label for="hubunganselect" class="form-label">Hubungan</label>
											<select class="form-select hubunganselect" name="hubungan"
												id="hubungan-id">
												<option th:each="option : ${dropValue}"
													th:value="${option.dropValueCode}"
													th:text="${option.dropValueName}"></option>

											</select>
										</div>
										<div class="col-md-6">
											<label for="statusOKU" class="form-label">Status OKU<span
												class="cus-red"></span></label>
											<div class="d-flex flex-wrap gap-md-5 gap-2">
												<div class="form-check">
													<input class="form-check-input statusUser" type="radio"
														value="ya" name="statusUser" /> <label
														class="form-check-label" for="ya2">Ya</label>
												</div>
												<div class="form-check">
													<input class="form-check-input statusUser" type="radio"
														name="statusUser" value="tidak" /> <label
														class="form-check-label" for="tidak2">Tidak</label>
												</div>
											</div>
										</div>
									</div>
									<div class="row mb-3">
										<div class="col-md-12">
											<input name="picImage" type="file" class="form-control"
												id="fileUploadfirst" />
										</div>
									</div>
								</div>
							</fieldset>
						</div>
					</div>
					<div class="mb-3">
						<fieldset id="fieldset-design">
							<legend id="legend-title">Maklumat Surat-Menyurat</legend>
							<div class="row mb-3">
								<div class="col-md-12">
									<label for="alamat" class="form-label">Alamat<span
										class="cus-red">*</span></label> <input type="text"
										class="form-control" id="Alamat" name="alamatSuratParent"
										required /> <span class="error-message" id="AlamatError"
										style="display: none;">Please enter Alamat</span>
								</div>
							</div>
							<div class="row mb-3 d-flex gap-md-5 gap-2">
								<div class="col-md-2 flex-grow-1">
									<label for="poskodphone" class="form-label">Poskod<span
										class="cus-red">*</span></label> <input type="tel"
										class="form-control" id="poskodphones" maxlength="5"
										name="poskodSuratParent" pattern="\d{1,5}" /> <span
										class="error-message" id="PoskodError" style="display: none;">Please
										enter Poskod</span>
								</div>
								<div class="col-md-2 flex-grow-1">
									<label for="bandar" class="form-label">Bandar</label> <input
										type="tel" class="form-control" id="bandar" name="bandar" />
								</div>
								<div class="col-md-2 flex-grow-1">
									<label for="negeri" class="form-label">Negeri<span
										class="cus-red">*</span></label> <input type="text"
										class="form-control" id="negeriId" name="negeri" /> <span
										class="error-message" id="negeriError" style="display: none;">This
										field is required</span>
								</div>
							</div>
						</fieldset>
					</div>
					<div class="mb-3">
						<fieldset id="fieldset-design">
							<legend id="legend-title">Maklumat Lanjut</legend>
							<div class="row mb-3 px-4">
								<div class="col-md-12">
									<div
										class="d-flex flex-wrap justify-content-between gap-md-5 gap-2">
										<label for="kakitanganppj" class="form-label"> <span
											class="d-md-block">Adakah ahli keluarga anda merupakan
												<span class="cus-red">*</span>
										</span> <span class="d-md-block">kakitangan PPJ? <span
												class="cus-red">*</span></span>
										</label>
										<div class="d-flex gap-5">
											<div class="form-check">
												<input class="form-check-input" type="radio" id="ya3"
													value="ya" required
													name="Adakah_ahli_keluarga_anda_merupakan" /> <label
													class="form-check-label" for="ya3">Ya</label>
											</div>
											<div class="form-check">
												<input class="form-check-input" type="radio" id="tidak3"
													value="tidak" name="Adakah_ahli_keluarga_anda_merupakan" />
												<label class="form-check-label" for="tidak3">Tidak</label>
											</div>
											<span class="error-message" style="display: none;">This
												field is required</span>
										</div>
									</div>
								</div>

								<div class="col-md-12">
									<!--         <label for="lampiranphone" class="form-label">Lampiran<span class="cus-red">*</span></label>
 -->
									<input type="file" class="form-control" id="lampiranId1"
										name="paspekerja" />
									<!--         <span class="error-message" id="errorFile2" style="display: none;">Please choose file or img</span>
 -->
								</div>
							</div>
							<div class="row mb-3 px-4">
								<div class="col-md-12">
									<div
										class="d-flex flex-wrap justify-content-between gap-md-5 gap-2">
										<label for="berstatusoku" class="form-label">Adakah
											anda berstatus OKU?<span class="cus-red"></span>
										</label>
										<div class="d-flex gap-5">
											<div class="form-check">
												<input class="form-check-input" type="radio"
													name="radioPasanganStaff" id="ya4" value="ya" /> <label
													class="form-check-label" for="ya4">Ya</label>
											</div>
											<div class="form-check">
												<input class="form-check-input" type="radio"
													name="radioPasanganStaff" id="tidak4" value="tidak" /> <label
													class="form-check-label" for="tidak4">Tidak</label>
											</div>
										</div>
										<!-- <span class="error-message" style="display: none;">This
											field is required</span> -->
									</div>
								</div>

								<div class="col-md-12">
									<label for="lampiranphone" class="form-label">Lampiran<span
										class="cus-red"></span></label> <input type="file"
										class="form-control" id="lampiranId2" name="paspekerjas" /> <span
										class="error-message" id="errorFile3" style="display: none;">Please
										choose file or img</span>
								</div>

							</div>
						</fieldset>
					</div>
					<div class="mb-3">
						<fieldset id="fieldset-design">
							<legend id="legend-title">Maklumat Pembayaran</legend>
							<div class="row px-4">
								<div class="col-md-12 mt-2">
									<div class="table_responsive">
										<table class="table table-bordered">
											<thead>
												<tr>
													<th scope="col">Pilih</th>
													<th scope="col">ID Pengguna</th>
													<th scope="col">Hubungan</th>
													<th scope="col">Status OKU</th>
													<th scope="col">Harga (RM)</th>
												</tr>
											</thead>
											<tbody id="tanggunganTableBody">
												<!-- Table rows will be dynamically added here -->
											</tbody>
										</table>
									</div>

									<div class="row">
										<div class="col-md-12">
											<div class="mt-3" id="RM-sum">
												Jumlah Harga: <span id="mySpan-sum">RM XX</span>
											</div>
										</div>
										<div class="col-md-12">
											<label for="lokasiPPK" class="form-label">Kaedah
												Pembayaran:</label> <select class="form-select" id="lokasiPPK">
												<option selected></option>
												<option value="Manual">Manual</option>
												<option value="fpx">FPX</option>
											</select>
										</div>
									</div>
								</div>
							</div>
						</fieldset>
					</div>
					<div>
						<fieldset id="fieldset-design">
							<legend id="legend-title">Terma & Syarat ahli PPK</legend>
							<ol class="px-4">
								<li>Anda mestilah individu warganegara Malaysia.</li>
								<li>Pastikan maklumat anda di Portal PPJ seperti nama,
									alamat, email, No K/P, no telefon adalah betul dan tepat.</li>
								<li>Anda akan di kenakan caj kad keahlian sebanyak RM 1.00
									kecuali untuk kakitangan PPJ, anak kakitangan PPJ, pasangan
									kakitangan PPJ, warga emas dan OKU</li>
							</ol>
							<div class="form-check">
								<input class="form-check-input" type="checkbox" value=""
									id="defaultCheck12" required="required" /> <label
									class="form-check-label" for="flexCheckDefault12"> Saya
									mengesahkan bahawa semua maklumat yang diberikan adalah benar
									dan tepat. Saya bertanggungjawab sepenuhnya atas sebarang
									ketidaktepatan atau maklumat palsu yang diberikan </label>
							</div>
						</fieldset>

						<div class="daftar_btn d-flex gap-4 justify-content-end">
							<button type="submit" id="submit-form">DAFTAR</button>
							<button onclick="cancell()">CANCEL</button>
						</div>
					</div>
				</form>
				
			</div>

		</div>



		<style>
* {
	margin: 0;
	box-sizing: border-box;
	font-family: Arial, Helvetica, sans-serif;
}

/* .membership-form form{ */
.membership-form :where(form, .maklumat-section) {
	box-shadow: rgba(0, 0, 0, 0.24) 0px 3px 8px;
	border-radius: 5px;
}

#memberform-id {
	padding: 2rem 4rem;
}

.membership-form {
	box-shadow: rgba(0, 0, 0, 0.24) 0px 3px 8px;
	background-color: #FFF;
}

.membership-form-main {
	margin: 3rem 4rem;
}

.membership-form-main h1 {
	text-align: center;
	font-weight: 700;
	font-size: 24px;
}

fieldset#fieldset-design {
	/* border: 1px solid #ccc; */
	/* border: 0px 0px 0px 0px; */
	padding: 1.5em;
	border-radius: 5px;
	position: relative;
}

legend#legend-title {
	font-weight: 400;
	padding: 0 10px;
	border-radius: 5px;
	background-color: #fff;
	width: fit-content;
	position: absolute;
	font-size: 16px;
	top: -14px;
	left: 30px;
}

.plusSign {
	width: fit-content;
	padding: 1px 13px;
	border-radius: 4px;
	border: 1px solid #00000020;
	background-color: transparent;
	font-size: 18px;
}

.plusSign:hover {
	box-shadow: rgba(0, 0, 0, 0.35) 0px 5px 15px;
}

.radio-custom-width {
	width: 30%;
}

.cus-red {
	color: red;
	margin-left: 2px;
	font-size: 20px;
}

.daftar_btn>button {
	border: none;
	font-size: 16px;
	font-weight: 500;
	padding: 6px 16px;
	border-radius: 6px;
	letter-spacing: 1px;
}

.daftar_btn>button:first-child {
	background-color: rgb(32, 78, 59);
	color: #FFF;
}

.daftar_btn>button:last-child {
	background-color: rgb(234, 238, 237);
	color: #000;
	letter-spacing: 0.5px;
}

.daftar_btn>button:hover {
	box-shadow: rgba(0, 0, 0, 0.35) 0px 5px 15px;
}

.form-check-input:checked {
	background-color: rgb(69, 69, 69) !important;
	border-color: rgb(69, 69, 69) !important;
}

@media screen and (max-width:768px) {
	.table_responsive {
		overflow-x: auto;
	}
	#memberform-id {
		margin: 2rem 1rem;
	}
}
</style>
		<style>
.error {
	border: 2px solid red;
}

.error-message {
	color: red;
	font-size: 12px;
}
</style>
		 <script type="text/javascript" th:src="@{/js/registration.js}"></script>

<script>
function cancell(){
	 $("#formId").attr("novalidate", "novalidate");
	window.location.href="http://ppk3.ppj.gov.my/index.php/e-borang/"
}

</script>
	</section>

</body>
</html>
