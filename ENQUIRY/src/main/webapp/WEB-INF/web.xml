<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://java.sun.com/xml/ns/javaee" xmlns:web="http://java.sun.com/xml/ns/javaee" xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-app_2_5.xsd" id="WebApp_ID" version="2.5">
  <display-name>Spring Hello World</display-name>
  <welcome-file-list>
    <welcome-file>/</welcome-file>
  </welcome-file-list>
  <servlet>
    <servlet-name>springDispatcher</servlet-name>
    <servlet-class>
            org.springframework.web.servlet.DispatcherServlet
        </servlet-class>
    <init-param>
      <param-name>contextConfigLocation</param-name>
      <param-value>/WEB-INF/config/spring-context.xml</param-value>
    </init-param>
    <load-on-startup>1</load-on-startup>
  </servlet>
  <servlet-mapping>
    <servlet-name>springDispatcher</servlet-name>
    <url-pattern>/</url-pattern>
  </servlet-mapping>
  <servlet>
    <description></description>
    <display-name>AccessionDischarge</display-name>
    <servlet-name>AccessionDischarge</servlet-name>
    <servlet-class>com.ilmu.circulation.Charging.AccessionDischarge</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AccessionDischarge</servlet-name>
    <url-pattern>/AccessionDischarge</url-pattern>
  </servlet-mapping>
  <servlet>
    <description></description>
    <display-name>AccessionRenewal</display-name>
    <servlet-name>AccessionRenewal</servlet-name>
    <servlet-class>com.ilmu.circulation.Charging.AccessionRenewal</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AccessionRenewal</servlet-name>
    <url-pattern>/AccessionRenewal</url-pattern>
  </servlet-mapping>
</web-app>